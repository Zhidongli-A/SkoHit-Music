# Git - 保留 .git 目录以便自动更新
# 注意：不要排除 .git，否则容器内无法 git pull
.gitignore

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Virtual Environment
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Documentation
README.md
LICENSE

# Data (will be mounted as volume)
data/*.json
